# ── NewsAPI ───────────────────────────────────────────────────────────────────
NEWSAPI_KEY=your_newsapi_key_here

# ── Webhook (bot1) ───────────────────────────────────────────────────────────
WEBHOOK_SECRET=your_shared_webhook_secret_here
WEBHOOK_URL=http://127.0.0.1:8000/webhook/bot2

# ── Símbolos a monitorear ────────────────────────────────────────────────────
WATCHLIST=SPY,QQQ

# ── Comportamiento del ciclo ─────────────────────────────────────────────────
CYCLE_INTERVAL_HOURS=4
MIN_CONFIDENCE=0.65
COOLDOWN_HOURS=4

# ── Riesgo por operación ─────────────────────────────────────────────────────
DEFAULT_STOP_LOSS=0.02
DEFAULT_TAKE_PROFIT=0.04

# ── Modo de operación ────────────────────────────────────────────────────────
# true  → solo loguea, NO envía webhook real a bot1
# false → envía webhook real
DRY_RUN=true

# ── Telegram (opcional) ──────────────────────────────────────────────────────
# Si no configuras esto, las alertas simplemente se omiten sin error
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
